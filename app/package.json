{
  "name": "miptv",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "REACT_NATIVE_NODE_MODULES_DIR=$(pwd)/node_modules react-native run-ios",
    "pods": "REACT_NATIVE_NODE_MODULES_DIR=$(pwd)/node_modules pod install --project-directory=ios",
    "start": "react-native start",
    "web": "webpack serve --config webpack.config.js",
    "web:build": "webpack --config webpack.config.js --mode production",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc --noEmit --project tsconfig.web.json",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/stack": "^7.0.0",
    "@tanstack/react-query": "^5.0.0",
    "hls.js": "^1.6.16",
    "i18next": "^23.0.0",
    "react": "18.3.1",
    "react-i18next": "^14.0.0",
    "react-native": "npm:react-native-tvos@0.76.7-0",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-orientation-locker": "^1.7.0",
    "react-native-reanimated": "~3.15.0",
    "react-native-safe-area-context": "~4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-code-push": "^9.0.1",
    "react-native-video": "^6.19.2",
    "react-native-web": "^0.21.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-react": "^7.29.7",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "15.1.3",
    "@react-native/babel-preset": "0.76.7",
    "@react-native/eslint-config": "0.76.7",
    "@react-native/metro-config": "0.76.7",
    "@react-native/typescript-config": "0.76.7",
    "@types/react": "^18.3.0",
    "@types/react-test-renderer": "^18.3.0",
    "babel-jest": "^29.7.0",
    "babel-loader": "^10.1.1",
    "eslint": "^8.57.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "react-test-renderer": "18.3.1",
    "typescript": "5.0.4",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.5"
  },
  "pnpm": {
    "overrides": {
      "@react-native-community/cli-server-api": "15.1.3"
    }
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "testRegex": "(/__tests__/.*|(\\.|/)(test|spec))\\.(jsx?|tsx?)$",
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|react-native-.*)/)"
    ]
  }
}
