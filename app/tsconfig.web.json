{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "react-native": ["node_modules/react-native-web/src/index"]
    },
    "lib": [
      "es2019",
      "es2020.bigint",
      "es2020.date",
      "es2020.number",
      "es2020.promise",
      "es2020.string",
      "es2020.symbol.wellknown",
      "es2021.promise",
      "es2021.string",
      "es2021.weakref",
      "es2022.array",
      "es2022.object",
      "es2022.string",
      "dom"
    ]
  },
  "include": [
    "src/**/*.web.ts",
    "src/**/*.web.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "index.web.js"
  ],
  "exclude": ["node_modules"]
}
