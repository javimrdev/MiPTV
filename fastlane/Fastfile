default_platform(:ios)

CODEPUSH_APP_IOS     = ENV.fetch("CODEPUSH_APP_IOS",     "miptv-ios")
CODEPUSH_APP_ANDROID = ENV.fetch("CODEPUSH_APP_ANDROID", "miptv-android")

# ─── iOS ────────────────────────────────────────────────────────────────────

platform :ios do
  desc "Release a CodePush OTA update to iOS Staging"
  lane :codepush_staging do
    sh "npx appcenter codepush release-react \
      -a #{CODEPUSH_APP_IOS} \
      -d Staging \
      --sourcemap-output \
      --description \"#{options[:desc] || 'OTA update'}\""
  end

  desc "Promote iOS CodePush update from Staging to Production"
  lane :codepush_promote do
    sh "npx appcenter codepush promote \
      -a #{CODEPUSH_APP_IOS} \
      -s Staging \
      -d Production"
  end

  desc "Build and upload iOS to TestFlight"
  lane :beta do
    increment_build_number(xcodeproj: "app/ios/miptv.xcodeproj")
    build_app(
      scheme: "miptv",
      workspace: "app/ios/miptv.xcworkspace",
      export_method: "app-store",
    )
    upload_to_testflight(skip_waiting_for_build_processing: true)
  end
end

# ─── Android ────────────────────────────────────────────────────────────────

platform :android do
  desc "Release a CodePush OTA update to Android Staging"
  lane :codepush_staging do
    sh "npx appcenter codepush release-react \
      -a #{CODEPUSH_APP_ANDROID} \
      -d Staging \
      --sourcemap-output \
      --description \"#{options[:desc] || 'OTA update'}\""
  end

  desc "Promote Android CodePush update from Staging to Production"
  lane :codepush_promote do
    sh "npx appcenter codepush promote \
      -a #{CODEPUSH_APP_ANDROID} \
      -s Staging \
      -d Production"
  end

  desc "Build and upload Android to Play Store internal track"
  lane :beta do
    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: "app/android",
    )
    upload_to_play_store(track: "internal")
  end
end
